# ──────────────────────────────────────────────────────────────
# Production environment file template
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values, OR use
# Docker secrets (docker-compose.secrets.yml) for zero-copy
# secret deployment.
#
# Required secrets (no defaults):
#   OPENAI_API_KEY    — LLM provider API key
#   SECRET_KEY        — JWT signing secret (>=32 chars, random)
#   API_KEY           — API key for programmatic access
#
# Docker secret alternative:
#   Mount files at /run/secrets/<lowercase_name> in the container.
#   See DOCKER_SECRET_MAP in backend/app/config.py for the mapping.
# ──────────────────────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile

# ── Security (REQUIRED: change these in production) ──────────
SECRET_KEY=
API_KEY=

# ── Database (defaults work if using docker-compose) ─────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/ai_dev_team

# ── Redis / Celery ───────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Environment ──────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=info
LOG_FORMAT=json

# ── CORS (set to your frontend domain) ───────────────────────
CORS_ORIGINS=["https://your-frontend-domain.com"]
