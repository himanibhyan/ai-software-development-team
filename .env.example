# ── Required ──────────────────────────────────────────────────
# OpenAI API key for LLM agents
OPENAI_API_KEY=sk-your-key-here

# ── Optional (defaults shown) ────────────────────────────────
OPENAI_MODEL=gpt-4-turbo-preview

# Database — overridden in Docker; only needed for local runs
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_dev_team

# Redis — overridden in Docker; only needed for local runs
REDIS_URL=redis://localhost:6379/0

# ChromaDB — overridden in Docker; only needed for local runs
CHROMA_HOST=localhost
CHROMA_PORT=8000

# API
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=dev-api-key
SECRET_KEY=change-me-in-production

# CORS origins (JSON array)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
